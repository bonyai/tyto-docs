{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Tyto",
  "colors": {
    "primary": "#c6f24e",
    "light": "#c6f24e",
    "dark": "#9bbf3a"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#08090b"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo-dark.svg",
    "href": "https://tyto.run"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["index", "quickstart", "authentication"]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/nests",
              "concepts/sessions",
              "concepts/files",
              "concepts/previews",
              "concepts/snapshots",
              "concepts/holds"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/run-a-command",
              "guides/transfer-files",
              "guides/expose-a-preview",
              "guides/snapshot-and-fork",
              "guides/keepalive-holds",
              "guides/billing"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["cli-reference/overview"]
          },
          {
            "group": "Everyday",
            "pages": ["cli-reference/everyday"]
          },
          {
            "group": "Lifecycle",
            "pages": ["cli-reference/lifecycle"]
          },
          {
            "group": "Sessions",
            "pages": ["cli-reference/sessions"]
          },
          {
            "group": "Data",
            "pages": ["cli-reference/data"]
          },
          {
            "group": "Account",
            "pages": ["cli-reference/account"]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "TypeScript",
            "pages": ["sdks/typescript/installation", "sdks/typescript/usage"]
          },
          {
            "group": "Python",
            "pages": ["sdks/python/installation", "sdks/python/usage"]
          }
        ]
      },
      {
        "tab": "MCP Server",
        "groups": [
          {
            "group": "MCP Server",
            "pages": ["mcp/overview", "mcp/setup", "mcp/tools"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.yaml"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@tyto.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://tyto.run/login"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com"
    }
  },
  "api": {
    "openapi": "api-reference/openapi.yaml"
  }
}
